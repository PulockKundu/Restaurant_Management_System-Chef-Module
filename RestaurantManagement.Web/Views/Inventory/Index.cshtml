@model List<RestaurantManagement.Entities.Inventory>
@Html.Partial("_Message")


<div class="row pt-4">
    <div class="col-12">
        <h2>Available Ingredients</h2>
    </div>
    <hr />
</div>


<div class="row pt-2">
    <div class="col-12">

        <table class="table table-bordered table-hover">
            <tr class="table-info">
                <th>Ref</th>
                <th>Product Name</th>
                <th>Available Quantity</th>
                <th>Unit Type</th>
                

            </tr>

            @if (Model.Count == 0)
            {
                <tr class="table-secondary text-center">
                    <td colspan="4">No Availabe Ingredients</td>
                </tr>
            }
            else
            {
                foreach (var Inventory in Model)
                {
                   
      <tr>
                  <td>@Inventory.ID</td>
                   <td>@Inventory.ProductName</td>
                        <td>@Inventory.Quantity</td>

                        <td>@Inventory.Unit</td>
                        
</tr>
}

}
</table>

</div>
</div> 
