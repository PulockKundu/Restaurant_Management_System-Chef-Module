@model RestaurantManagement.Entities.Inventory

@Html.Partial("_Message")

<div class="container border mt-4 p-4">
    <div class="row">
        <div class="col-12">
            <h2>ADD Used Ingredients</h2>
        </div>
        <hr />
    </div>

    <form method="post" action="#">

        <div class="row mb-3">
            <label asp-for="ID" class="form-label">Product</label>
            <select asp-for="ID" asp-items="@ViewBag.ProductList" class="form-select">
                <option value="">--Select Product--</option>
            </select>
            <span asp-validation-for="ID" class="text-danger"></span>
        </div>

        <div class="row mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" type="number" min="1" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

       

        <div class="row mb-3">
            <div class="col-6">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy2"></i> &nbsp;Submit
                </button>
                &nbsp;
                <a asp-action="Index" asp-controller="Inventory" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left-circle"></i> &nbsp;Back
                </a>
            </div>
        </div>
    </form>
</div>






@section Scripts
{
    @Html.Partial("_ValidationScriptsPartial")
}