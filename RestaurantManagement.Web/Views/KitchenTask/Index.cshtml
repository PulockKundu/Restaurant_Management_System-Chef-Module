@model List<RestaurantManagement.Entities.KitchenTask>

@Html.Partial("_Message")

<div class="row pt-4">
    <div class="col-12">
        <h2>Manage Kitchen Task</h2>
    </div>
    
    <hr />
</div>

<div class="row pt-2">
    <div class="col-12">

        <table class="table table-bordered table-hover">
            <tr class="table-info">
                <th>Ref</th>
                <th>Ordered Item</th>
                <th>Ordered Quantity</th>
                @* <th>Chef Id</th> *@

                <th>Status</th>
                <th style="width:200px">Update Status</th>
            </tr>

            @if(Model.Count == 0)
            {
                <tr class="table-secondary text-center">
                    <td colspan="4">No Data to show.</td>
                </tr>
            } 
            else
            {
                foreach (var kitchenTask in Model)
                {
                    if (kitchenTask.Status != "Ready")
                    {
                        <tr>
                            <td>@kitchenTask.ID</td>
                            <td>@kitchenTask.MenuItemss.ItemsName</td>

                            <td>@kitchenTask.OrderItemss.OrderQuantity</td>
                          


                            <td>@kitchenTask.Status</td>

                            <td>
                                <a class="btn btn-info" asp-action="Detail" asp-controller="KitchenTask" asp-route-dataId="@kitchenTask.ID">
                                    <i class="bi bi-pencil-square"></i> &nbsp; Edit
                                </a>
                             
                            </td>

                        </tr>
                    }
                }
            }
        </table>

    </div>
</div>